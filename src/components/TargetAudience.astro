---
const audiences = [
  {
    icon: "brain",
    title: "Psicólogos",
    text: "Utilize o tangram como ferramenta lúdica em sessões de terapia, estimulandoexpressão emocional e autoconhecimento.",
    color: "bg-teal",
  },
  {
    icon: "mic",
    title: "Fonoaudiólogos",
    text: "Estimule linguagem, cognição e habilidades sociais de forma divertida e eficiente.",
    color: "bg-orange",
  },
  {
    icon: "book",
    title: "Professores",
    text: "Atividades lúdicas para sala de aula que desenvolvem raciocínio lógico e criatividade.",
    color: "bg-purple",
  },
  {
    icon: "home",
    title: "Pais e Cuidadores",
    text: "Brincadeiras terapêuticas para fazer em casa, fortalecendo vínculos e habilidades.",
    color: "bg-teal",
  },
  {
    icon: "hand",
    title: "Terapeutas Ocupacionais",
    text: "Coordenação motora fina, percepção visual e planejamento de forma prazerosa.",
    color: "bg-orange",
  },
  {
    icon: "graduation",
    title: "Psicopedagogos",
    text: "Aprendizagem de forma criativa, trabalhando atenção e resolução de problemas.",
    color: "bg-purple",
  },
];
---

<div class="rounded-2xl bg-cream/95 shadow-[0_20px_60px_-20px_rgba(60,40,20,0.35)] ring-1 ring-black/5 backdrop-blur mt-8 overflow-hidden">
  <div class="bg-teal px-6 py-4 text-center">
    <h2 class="font-display text-lg font-bold tracking-wide text-teal-foreground sm:text-xl">
      PARA QUEM É ESTE E-BOOK
    </h2>
  </div>

  <div class="grid gap-4 p-6 sm:grid-cols-3 sm:gap-5 sm:p-8">
    {audiences.map((item) => (
      <div class="rounded-xl bg-white/80 p-5 text-center shadow-[0_4px_20px_-8px_rgba(60,40,20,0.15)] ring-1 ring-black/5 transition hover:-translate-y-0.5 hover:shadow-lg">
        <div class={`mx-auto grid h-12 w-12 place-items-center rounded-full ${item.color} text-white shadow-md`}>
          {item.icon === "brain" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
          )}
          {item.icon === "mic" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
          )}
          {item.icon === "book" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          )}
          {item.icon === "home" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          )}
          {item.icon === "hand" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
          )}
          {item.icon === "graduation" && (
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 6 3 6 3s3 0 6-3v-5"/></svg>
          )}
        </div>
        <h3 class="mt-3 text-sm font-bold leading-snug tracking-wide text-ink sm:text-base">
          {item.title}
        </h3>
        <p class="mt-2 text-sm leading-relaxed text-ink/75 sm:text-[15px]">
          {item.text}
        </p>
      </div>
    ))}
  </div>
</div>
